@rendermode InteractiveServer
@page "/Game"
@using Microsoft.EntityFrameworkCore
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Processing
@using SlideMasters_BlazorApp.Models
@using System.Timers
@using SixLabors.ImageSharp.PixelFormats
@using Microsoft.AspNetCore.Components.Web
@inject IWebHostEnvironment Environment
@inject NavigationManager NavigationManager
@inject HttpClient HttpClient
@inject IDbContextFactory<DBContextService> DbFactory

<PageTitle>Slide Masters - Game</PageTitle>

<div class="game-container">
    <h1>Slide Masters</h1>

    @if (hasLoaded && IsTimed)
    {
        <h4>Time: @FormatTime(secondsRemaining)</h4>
    }

    @if (ImageSource != null)
    {
        <div class="image-info">
            <h3>Puzzle - @DifficultyLevel Difficulty (@gridWidth x @gridHeight)</h3>
            <p><strong>Image:</strong> @(ImageSource.Contains("http") ? "Custom URL" : Path.GetFileName(ImageSource))</p>
            @if (ImageWidth > 0 && ImageHeight > 0)
            {
                <p><strong>Resolution:</strong> @ImageWidth x @ImageHeight pixels</p>
            }
            
            @if (hasWon && !IsTimed)
            {
                <div class="alert alert-success mt-3" role="alert">
                    <h4 class="alert-heading">Congratulations!</h4>
                    <p>You've successfully solved the puzzle!</p>
                    <hr>
                    <button class="btn btn-outline-success" @onclick="GoBack">Play Again</button>
                </div>
            }
            else if (hasWon && IsTimed && showNameInput)
            {
                <div class="alert alert-success mt-3" role="alert">
                    <h4 class="alert-heading">Congratulations!</h4>
                    <p>You completed the puzzle in @FormatTime(secondsRemaining)!</p>
                    <hr>
                    <div class="arcade-name-selector" 
                         @onkeydown="HandleKeyDown" 
                         @onkeydown:stopPropagation="true"
                         tabindex="0">
                        <label class="form-label">Enter your initials for the high score:</label>
                        <div class="name-input-container">
                            @for (int i = 0; i < 3; i++)
                            {
                                int letterIndex = i; // Capture for closure
                                <div class="letter-selector @(selectedLetterIndex == letterIndex ? "selected" : "")">
                                    <button type="button" class="btn btn-sm btn-outline-primary arrow-btn" @onclick="() => CycleLetter(letterIndex, 1)">
                                        <span>▲</span>
                                    </button>
                                    <div class="letter-display" @onclick="() => SelectLetter(letterIndex)">@playerInitials[letterIndex]</div>
                                    <button type="button" class="btn btn-sm btn-outline-primary arrow-btn" @onclick="() => CycleLetter(letterIndex, -1)">
                                        <span>▼</span>
                                    </button>
                                </div>
                            }
                        </div>
                        <div class="name-preview">@string.Join("", playerInitials)</div>
                        <div class="arcade-instructions">
                            <small>Click letters to select • Use ▲▼ buttons or arrow keys • Press Enter to save</small>
                        </div>
                    </div>
                    <button class="btn btn-primary me-2" @onclick="SaveScore">Save Score</button>
                    <button class="btn btn-outline-success" @onclick="GoBack">Play Again</button>
                </div>
            }
            else if (hasWon && IsTimed && hasAlreadySaved)
            {
                <div class="alert alert-success mt-3" role="alert">
                    <h4 class="alert-heading">Score Saved!</h4>
                    <p>Your time of @FormatTime(secondsRemaining) has been recorded!</p>
                    <hr>
                    <button class="btn btn-outline-success me-2" @onclick="GoToHighScores">View High Scores</button>
                    <button class="btn btn-outline-success" @onclick="GoBack">Play Again</button>
                </div>
            }

            <div class="puzzle">
                <div class="puzzle-grid" style="--grid-cols: @gridWidth;">
                    @if (GameController.slidingPuzzleBlocks.Count > 0)
                    {
                        //Draw puzzle grid
                        for (int i = 0; i < GameController.slidingPuzzleBlocks.Count; i++)
                        {
                            @UpdateBlocks(i)
                            ;
                        }
                    }
                </div>
            </div>
        </div>
    }

    <div class="button-container">
        @if (IsTimed)
        {
            <button class="btn btn-secondary" @onclick="GoToHighScores">View High Scores</button>
        }
        <button class="btn btn-secondary" @onclick="GoBack">Back to Main Menu</button>
        @* Debug button - remove in production *@
        <button class="btn btn-warning" @onclick="TestWinCondition">Test Win (Debug)</button>
    </div>
</div>

@code
{
    [Parameter][SupplyParameterFromQuery] public string? ImagePath { get; set; }
    [Parameter][SupplyParameterFromQuery] public bool IsTimed { get; set; }

    [Parameter][SupplyParameterFromQuery] public int difficultyLevel { get; set; }
    public DifficultyLevel DifficultyLevel => (DifficultyLevel)difficultyLevel;


    //Public
    public GameController GameController { get; set; } = new GameController();
    public int emptyBlockIndex = 0;
    public bool hasLoaded = false;
    public bool hasWon = false;

    private int startingTime = 60;
    

    //Private
    private string? ImageSource { get; set; }
    private int ImageWidth { get; set; }
    private int ImageHeight { get; set; }

    private ImageSplitter imageSplitter = new ImageSplitter();
    private int gridWidth = 4;
    private int gridHeight = 4;

    private int secondsRemaining { get; set; }
    private Timer? timer { get; set; }
    private string playerName { get; set; } = string.Empty;
    private char[] playerInitials { get; set; } = { 'A', 'A', 'A' };
    private int selectedLetterIndex { get; set; } = 0;
    private bool showNameInput { get; set; } = false;
    private bool hasAlreadySaved { get; set; } = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // OnAfterRender only runs on the client after the interactive SignalR circuit
        // is established — never during static pre-render, so WebRootPath is always valid here.
        if (!firstRender) return;

        if (string.IsNullOrEmpty(ImagePath))
        {
            ImagePath = "/Images/Static/redToji.jpg"; // Default fallback
        }

        // Set grid size based on difficulty
        DetermineGridSize();

        await LoadImageData(ImagePath);

        if (IsTimed)
        {
            StartTimer();
        }
    }

    //Render the blocks as the values change (must be rendered in code)
    private RenderFragment<int> UpdateBlocks => value => __builder =>
    {
        var block = GameController.slidingPuzzleBlocks[value];
        <img class="puzzle-piece" src="@block.DataUri" @onclick="(() => OnClickBlock(value))" alt="Image Block" />
    };

    //Updates and swaps blocks if the clicked block is adjacent to the empty block
    private void OnClickBlock(int index)
    {
        if (!hasWon && index < GameController.slidingPuzzleBlocks.Count)
        {
            ImageBlock clickedBlock = GameController.slidingPuzzleBlocks[index];

            //Clicking the empty block should do nothing, so we check the other blocks
            if (!clickedBlock.IsEmptyBlock)
            {
                //get orthogonal positions
                bool upCoords = FindImageBlock(clickedBlock.BoardX, clickedBlock.BoardY - 1);
                bool downCoords = FindImageBlock(clickedBlock.BoardX, clickedBlock.BoardY + 1);
                bool leftCoords = FindImageBlock(clickedBlock.BoardX - 1, clickedBlock.BoardY);
                bool rightCoords = FindImageBlock(clickedBlock.BoardX + 1, clickedBlock.BoardY);

                int firstIndex = GetImageBlockIndex(clickedBlock.BoardX, clickedBlock.BoardY);

                if (upCoords)
                {
                    //block above clicked block
                    int secondIndex = GetImageBlockIndex(clickedBlock.BoardX, clickedBlock.BoardY - 1);

                    //if it's empty && not out of bounds, swap
                    if (GameController.slidingPuzzleBlocks[secondIndex].IsEmptyBlock && secondIndex != -1)
                    {
                        GameController.SwapBlocks(firstIndex, secondIndex);
                        CheckWinCondition();
                        return;
                    }
                }
                if (downCoords)
                {
                    //block under clicked block
                    int secondIndex = GetImageBlockIndex(clickedBlock.BoardX, clickedBlock.BoardY + 1);

                    //if it's empty && not out of bounds, swap
                    if (GameController.slidingPuzzleBlocks[secondIndex].IsEmptyBlock && secondIndex != -1)
                    {
                        GameController.SwapBlocks(firstIndex, secondIndex);
                        CheckWinCondition();
                        return;
                    }
                }
                if (leftCoords)
                {
                    //block to the left of clicked block
                    int secondIndex = GetImageBlockIndex(clickedBlock.BoardX - 1, clickedBlock.BoardY);

                    //if it's empty && not out of bounds, swap
                    if (GameController.slidingPuzzleBlocks[secondIndex].IsEmptyBlock && secondIndex != -1)
                    {
                        GameController.SwapBlocks(firstIndex, secondIndex);
                        CheckWinCondition();
                        return;
                    }
                }
                if (rightCoords)
                {
                    //block to the right of clicked block
                    int secondIndex = GetImageBlockIndex(clickedBlock.BoardX + 1, clickedBlock.BoardY);

                    //if it's empty && not out of bounds, swap
                    if (GameController.slidingPuzzleBlocks[secondIndex].IsEmptyBlock && secondIndex != -1)
                    {
                        GameController.SwapBlocks(firstIndex, secondIndex);
                        CheckWinCondition();
                        return;
                    }
                }
                //block not found, do not search for empty block
                else
                {
                    return;
                }
            }
        }
    }

    private void CheckWinCondition()
    {
        bool isCompleted = GameController.IsCompleted();
        Console.WriteLine($"CheckWinCondition called. IsCompleted: {isCompleted}, hasWon: {hasWon}");
        
        if (!hasWon && isCompleted)
        {
            hasWon = true;
            Console.WriteLine($"Puzzle completed! IsTimed: {IsTimed}");
            
            if (IsTimed)
            {
                timer?.Stop();
                showNameInput = true;
                // Reset initials for new entry
                playerInitials = new char[] { 'A', 'A', 'A' };
                selectedLetterIndex = 0;
                Console.WriteLine($"Timer stopped. Final time: {secondsRemaining} seconds");
            }
            
            StateHasChanged();
        }
    }

    private async Task SaveScore()
    {
        if (!hasAlreadySaved)
        {
            string finalName = string.Join("", playerInitials);
            using var context = DbFactory.CreateDbContext();
            context.AddNewScore(new GameScore(finalName, secondsRemaining, DifficultyLevel));
            await context.SaveChangesAsync();
            hasAlreadySaved = true;
            showNameInput = false;
            StateHasChanged();
        }
    }

    private void CycleLetter(int position, int direction)
    {
        char currentLetter = playerInitials[position];
        int currentIndex = currentLetter - 'A';
        
        // Cycle through A-Z (0-25)
        currentIndex += direction;
        
        if (currentIndex < 0)
            currentIndex = 25; // Wrap to Z
        else if (currentIndex > 25)
            currentIndex = 0; // Wrap to A
        
        playerInitials[position] = (char)('A' + currentIndex);
        StateHasChanged();
    }

    private void SelectLetter(int index)
    {
        selectedLetterIndex = index;
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key.ToLower())
        {
            case "arrowup":
                CycleLetter(selectedLetterIndex, 1);
                break;
            case "arrowdown":
                CycleLetter(selectedLetterIndex, -1);
                break;
            case "arrowleft":
                selectedLetterIndex = selectedLetterIndex > 0 ? selectedLetterIndex - 1 : 2;
                StateHasChanged();
                break;
            case "arrowright":
                selectedLetterIndex = selectedLetterIndex < 2 ? selectedLetterIndex + 1 : 0;
                StateHasChanged();
                break;
            case "enter":
                _ = SaveScore(); // Fire and forget the async method
                break;
        }
    }

    private async Task LoadImageData(string imagePath)
    {
        ImageSource = imagePath;
        string? tempFilePath = null;

        try
        {
            string physicalPath;

            if (imagePath.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            {
                // Download the URL image to a temp file so ImageSplitter (which needs a path) can use it
                var imageBytes = await HttpClient.GetByteArrayAsync(imagePath);

                // Detect extension from URL, fall back to .jpg
                string ext = ".jpg";
                try
                {
                    var uriPath = new Uri(imagePath).AbsolutePath;
                    var uriExt = Path.GetExtension(uriPath);
                    if (!string.IsNullOrEmpty(uriExt) && uriExt.Length <= 5) ext = uriExt;
                }
                catch { /* ignore, use default */ }

                tempFilePath = Path.Combine(Path.GetTempPath(), $"{Guid.NewGuid()}{ext}");
                await File.WriteAllBytesAsync(tempFilePath, imageBytes);
                physicalPath = tempFilePath;
            }
            else
            {
                // Normalize forward slashes to the OS path separator before combining
                var relativePath = imagePath.TrimStart('/').Replace('/', Path.DirectorySeparatorChar);
                var webRoot = Environment.WebRootPath;
                if (string.IsNullOrEmpty(webRoot))
                {
                    // WebRootPath can be null/empty during SSR pre-render — abort early
                    Console.WriteLine("WebRootPath is empty, skipping load (pre-render phase)");
                    return;
                }
                physicalPath = Path.Combine(webRoot, relativePath);
                Console.WriteLine($"Resolved physical path: {physicalPath}");
            }

            using var image = Image.Load<Rgba32>(physicalPath);

            ImageHeight = image.Height;
            ImageWidth = image.Width;

            try
            {
                // Split the image into puzzle blocks.
                var getBlocks = imageSplitter.SplitImage(physicalPath, gridHeight * gridWidth);

                for (int i = 0; i < getBlocks.Length; i++)
                {
                    var block = new ImageBlock(getBlocks[i]) { BoardID = i };
                    GameController.slidingPuzzleBlocks.Add(block);
                }

                // Remove the last block to make room for the empty sliding tile
                emptyBlockIndex = GameController.slidingPuzzleBlocks.Count - 1;
                GameController.slidingPuzzleBlocks.RemoveAt(emptyBlockIndex);

                // Load and resize the empty block placeholder to match tile size
                var emptyBlock = Image.Load(Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "Images", "Static", "empty_block.png"));
                emptyBlock.Mutate(ctx => ctx.Resize(ImageWidth / gridWidth, ImageHeight / gridHeight));
                var imgEmptyBlock = new ImageBlock(emptyBlock) { IsEmptyBlock = true, BoardID = emptyBlockIndex };

                // Add the empty block at the end
                GameController.slidingPuzzleBlocks.Add(imgEmptyBlock);

                // Shuffle the pieces to make the game playable
                // Two shuffle methods available:
                // 1. SimpleShufflePuzzle: Performs valid moves from solved state (guaranteed solvable)
                // 2. ShufflePuzzle: Uses mathematical inversion counting (more random but complex)
                ImageRandomizer.SimpleShufflePuzzle(GameController.slidingPuzzleBlocks, gridWidth, 500);

                hasLoaded = true;
                
                // Check win condition after loading (in case puzzle is already solved)
                CheckWinCondition();
                
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception spl)
            {
                Console.WriteLine($"Error while splitting image: {spl.Message}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading image: {ex.Message}");
        }
        finally
        {
            // Clean up the temp file if one was created for a URL image
            if (tempFilePath != null && File.Exists(tempFilePath))
            {
                try { File.Delete(tempFilePath); } catch { /* best effort */ }
            }
        }
    }

    private bool FindImageBlock(int boardX, int boardY)
    {
        ImageBlock? imgBlock = GameController.slidingPuzzleBlocks.Find(img => img.BoardX == boardX && img.BoardY == boardY);

        return (imgBlock == null) ? false : true;
    }

    private int GetImageBlockIndex(int boardX, int boardY)
    {
        ImageBlock? imgBlock = GameController.slidingPuzzleBlocks.Find(img => img.BoardX == boardX && img.BoardY == boardY);
        return (imgBlock == null) ? -1 : GameController.slidingPuzzleBlocks.IndexOf(imgBlock);
    }
    
    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private void GoToHighScores()
    {
        NavigationManager.NavigateTo("/highscores");
    }

    private void StartTimer()
    {
        secondsRemaining = 0;
        timer = new Timer(1000);
        timer.Elapsed += OnTimedEvent;
        timer.AutoReset = true;
        timer.Enabled = true;
    }

    private void DetermineGridSize()
    {
        switch (DifficultyLevel)
        {
            case DifficultyLevel.Easy:
                gridWidth = 3;
                gridHeight = 3;
                break;
            case DifficultyLevel.Medium:
                gridWidth = 4;
                gridHeight = 4;
                break;
            case DifficultyLevel.Hard:
                gridWidth = 5;
                gridHeight = 5;
                break;
        }
    }

    private void OnTimedEvent(object sender, ElapsedEventArgs e)
    {
        if (!hasWon)
        {
            //Increment timer while solving
            secondsRemaining++;
            InvokeAsync(StateHasChanged);
        }
    }

    private void TestWinCondition()
    {
        Console.WriteLine("Manual win condition test triggered");
        CheckWinCondition();
    }

    private string FormatTime(int seconds)
    {
        int minutes = seconds / 60;
        int remainingSeconds = seconds % 60;
        return $"{minutes:D2}:{remainingSeconds:D2}";
    }
}
